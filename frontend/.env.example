# --- Local dev (Vite proxies /api → localhost:8080) ---
VITE_USE_API=true
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional overrides (local dev usually does not need these):
# VITE_APP_URL=http://localhost:5173
# VITE_API_URL=http://localhost:8080/api

# --- Production (set in Vercel → Settings → Environment Variables) ---
# VITE_USE_API=true
# VITE_APP_URL=https://site-activation-log.vercel.app
# VITE_API_URL=https://YOUR-DEPLOYED-API-HOST/api
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
#
# Google OAuth: add https://site-activation-log.vercel.app as an authorized JavaScript origin.
